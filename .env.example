# ── Secrets (required) ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
COHERE_API_KEY=your-cohere-key

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://raguser:ragpass@localhost:5434/ragdb

# ── Models (override for the official metric run) ─────────────────────────────
# Defaults are the cost-conscious dev models. For the final portfolio run:
#   GENERATION_MODEL=claude-sonnet-5
#   JUDGE_MODEL=claude-opus-4-8
# and supply a Cohere *production* key above (trial keys cap at 10 req/min).
EMBEDDING_MODEL=text-embedding-3-small
GENERATION_MODEL=claude-sonnet-4-6
QUERY_REWRITE_MODEL=claude-haiku-4-5-20251001
RERANK_MODEL=rerank-english-v3.0
JUDGE_MODEL=claude-sonnet-5

# ── Client reliability ────────────────────────────────────────────────────────
OPENAI_TIMEOUT_S=30
OPENAI_MAX_RETRIES=3
ANTHROPIC_TIMEOUT_S=60
ANTHROPIC_MAX_RETRIES=2
COHERE_TIMEOUT_S=15

# ── Pipeline behavior ─────────────────────────────────────────────────────────
RELEVANCE_THRESHOLD=0.3

# ── API surface ───────────────────────────────────────────────────────────────
# When RAG_API_KEY is set, /ask and /ingest require a matching X-API-Key header.
# Leave unset for open local development.
RAG_API_KEY=
CORS_ORIGINS=http://localhost:8501
LOG_FORMAT=text

# ── UI ────────────────────────────────────────────────────────────────────────
RAG_API_BASE_URL=http://localhost:8000
